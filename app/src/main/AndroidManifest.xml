<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ML Kit downloads the translation model from Google Play services on first use. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Daily 09:00 notification. Required at runtime on Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.EduPsychDaily">

        <!-- Tell ML Kit to download the Korean translation model when the app installs. -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="translate" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.EduPsychDaily">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".notify.TestNotifyReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.cherin.edupsych.TEST_NOTIFY" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".widget.TodayWidgetReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/today_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.FavoritesWidgetReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/favs_widget_info" />
        </receiver>
    </application>

</manifest>
